# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored; this `.env.example` is committed for reference.

# Contact form
FORMSPREE_FORM_ID=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# Google Maps (restrict by HTTP referrer in Google Cloud Console)
GOOGLE_MAPS_API_KEY=

# Analytics
GA_MEASUREMENT_ID=

# reCAPTCHA
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Server-only secrets (DO NOT expose to client)
SENDGRID_API_KEY=
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
